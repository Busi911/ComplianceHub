// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id                    String   @id @default(cuid())
  ean                   String   @unique
  internalArticleNumber String?
  manufacturer          String?
  brand                 String?
  productName           String
  category         String?
  subcategory      String?
  ekPrice          Float?
  netWeightG       Float?
  grossWeightG     Float?
  netLengthMm      Float?
  netWidthMm       Float?
  netHeightMm      Float?
  grossLengthMm    Float?
  grossWidthMm     Float?
  grossHeightMm    Float?
  // Hersteller-Angaben (vom Hersteller gelieferte Werte, separat von gemessenen/geschätzten Werten)
  mfrNetWeightG    Float?   // Hersteller-Angabe: Nettogewicht (g)
  mfrGrossWeightG  Float?   // Hersteller-Angabe: Bruttogewicht inkl. Verpackung (g)
  mfrPlasticG      Float?   // Hersteller-Angabe: Kunststoff-Fraktion (g)
  mfrPaperG        Float?   // Hersteller-Angabe: Papier-/Karton-Fraktion (g)
  annualUnitsSold      Int?
  samplingSkipReason   String?   // null = not skipped; "out_of_stock" | "discontinued" | "other"
  samplingSkippedAt    DateTime?
  source               String?
  importBatchId        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  importBatch      ImportBatch?             @relation(fields: [importBatchId], references: [id])
  packagingProfile ProductPackagingProfile?
  samplingRecords  SamplingRecord[]
  estimateHistory  ProductEstimateHistory[]
  auditLogs        AuditLog[]               @relation("ProductAuditLogs")
  manufacturerRequestItems ManufacturerRequestItem[]
  manufacturerBufferMatches ManufacturerDataBuffer[]
  complianceScore  ProductComplianceScore?
  batteryProfile   ProductBatteryProfile?
  weeeProfile      ProductWeeeProfile?
  levyProfile      ProductLevyProfile?
  reachProfile     ProductReachProfile?
  rohsProfile      ProductRohsProfile?
  eudrProfile      ProductEudrProfile?
  popProfile       ProductPopProfile?

  @@index([category])
  @@index([brand])
  @@index([manufacturer])
  @@index([importBatchId])
}

model ProductPackagingProfile {
  id               String   @id @default(cuid())
  productId        String   @unique
  status           PackagingStatus @default(IMPORTED)
  estimatedPlasticG Float?
  estimatedPaperG   Float?
  measuredPlasticG  Float?
  measuredPaperG    Float?
  currentPlasticG   Float?
  currentPaperG     Float?
  confidenceScore   Float?   // 0.0 - 1.0
  estimationMethod  String?
  estimationErrorPct Float?  // % error when first measured vs prior estimate (+ = overestimated)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SamplingRecord {
  id                    String   @id @default(cuid())
  productId             String
  sampledAt             DateTime @default(now())
  sampledBy             String?
  measuredPlasticG      Float?
  measuredPaperG        Float?
  measuredTotalPackagingG Float?
  netWeightAtSamplingG  Float?
  grossWeightAtSamplingG Float?
  notes                 String?
  isOutlier             Boolean  @default(false)
  outlierReason         String?
  createdAt             DateTime @default(now())

  product               Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ImportBatch {
  id             String   @id @default(cuid())
  name           String
  sourceFileName String?
  importedAt     DateTime @default(now())
  rowCount       Int      @default(0)
  successCount   Int      @default(0)
  errorCount     Int      @default(0)
  notes          String?

  products       Product[]
}

model CronRun {
  id         String   @id @default(cuid())
  type       String   @default("reestimate")
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  total      Int      @default(0)
  updated    Int      @default(0)
  skipped    Int      @default(0)
  errors     Int      @default(0)
  durationMs Int?

  historyEntries ProductEstimateHistory[]
}

model ProductEstimateHistory {
  id          String   @id @default(cuid())
  productId   String
  cronRunId   String?
  oldPlasticG Float?
  oldPaperG   Float?
  newPlasticG Float?
  newPaperG   Float?
  reason      String?
  method      String?
  createdAt   DateTime @default(now())

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  cronRun     CronRun? @relation(fields: [cronRunId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([cronRunId])
  @@index([createdAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  action        String
  oldValuesJson String?
  newValuesJson String?
  createdAt     DateTime @default(now())

  product       Product? @relation("ProductAuditLogs", fields: [entityId], references: [id], map: "AuditLog_productId_fkey")

  @@index([entityType, entityId])
}

model BrandProfile {
  id              String   @id @default(cuid())
  entityType      String   // "brand" | "manufacturer"
  name            String
  notes           String?  // free-text observations about packaging behaviour
  packagingStyle  String?  // e.g. "minimal", "oversized", "eco-freundlich"
  typicalMaterial String?  // e.g. "überwiegend Plastik", "überwiegend Karton"
  tagsJson        String?  // JSON array of tag strings
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([entityType, name])
  @@index([name])
}

model ManufacturerRequest {
  id               String   @id @default(cuid())
  manufacturerName String
  contactEmail     String?
  status           String   @default("OFFEN")  // OFFEN | GESENDET | BEANTWORTET | GESCHLOSSEN
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items            ManufacturerRequestItem[]
}

model ManufacturerRequestItem {
  id        String   @id @default(cuid())
  requestId String
  productId String
  notes     String?
  createdAt DateTime @default(now())

  request   ManufacturerRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  product   Product             @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([requestId, productId])
  @@index([requestId])
  @@index([productId])
}

// Hersteller senden ihre Artikeldaten vorab mit EAN oder interner Artikelnummer.
// Solange der Artikel noch nicht im Sortiment ist, liegen die Daten im Puffer.
// Sobald ein Produkt mit passender EAN / interner Artikelnummer importiert wird, werden die Herstellerdaten automatisch übernommen.
model ManufacturerDataBuffer {
  id                 String    @id @default(cuid())
  ean                String?   // EAN bevorzugt; optional wenn internalArticleNr gesetzt
  internalArticleNr  String?   // interne Artikelnummer als Fallback-Identifier
  manufacturerName   String?
  productName        String?
  mfrNetWeightG      Float?
  mfrGrossWeightG    Float?
  mfrPlasticG        Float?
  mfrPaperG          Float?
  extraJson          String?   // alle weiteren CSV-Spalten als JSON
  sourceFileName     String?
  matchedProductId   String?
  matchedAt          DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  matchedProduct     Product?  @relation(fields: [matchedProductId], references: [id])

  @@index([ean])
  @@index([internalArticleNr])
  @@index([matchedProductId])
}

model SamplingPreset {
  id          String   @id @default(cuid())
  name        String
  description String?
  productIds  String   // JSON array of product IDs
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PackagingStatus {
  IMPORTED
  ESTIMATED
  SAMPLED
  REVIEWED
}

// ─── Compliance Hub ──────────────────────────────────────────────────────────

enum ComplianceStatus {
  NOT_APPLICABLE
  UNKNOWN
  ESTIMATED
  DECLARED
  VERIFIED
}

model ProductComplianceScore {
  id               String   @id @default(cuid())
  productId        String   @unique
  overallScore     Float    @default(0)
  battScore        Float?
  weeeScore        Float?
  levyScore        Float?
  reachScore       Float?
  rohsScore        Float?
  eudrScore        Float?
  popScore         Float?
  applicableCount  Int      @default(0)
  completedCount   Int      @default(0)
  lastComputedAt   DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum BatteryType {
  LI_ION
  NIMH
  ALKALINE
  NICD
  LEAD_ACID
  OTHER
}

model ProductBatteryProfile {
  id                  String           @id @default(cuid())
  productId           String           @unique
  status              ComplianceStatus @default(UNKNOWN)
  containsBattery     Boolean?
  batteryType         BatteryType?
  batteryWeightG      Float?
  batteryCapacityMah  Float?
  batteryCapacityWh   Float?
  isRemovable         Boolean?
  earRegistrationNr   String?
  annualBatteryTonnes Float?
  confidenceScore     Float?
  estimationMethod    String?
  aiClassifiedAt      DateTime?
  notes               String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  product             Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum WeeeCategory {
  HAUSHALTSGROSSE_GERATE
  HAUSHALTSKLEINGERATE
  IT_TELEKOMMUNIKATION
  UNTERHALTUNGSELEKTRONIK
  BELEUCHTUNG
  WERKZEUGE
  SPIELZEUG_FREIZEIT_SPORT
  MEDIZINPRODUKTE
  UEBERWACHUNGS_INSTRUMENTE
  AUTOMATEN
}

model ProductWeeeProfile {
  id               String           @id @default(cuid())
  productId        String           @unique
  status           ComplianceStatus @default(UNKNOWN)
  isElectronic     Boolean?
  weeeCategory     WeeeCategory?
  earWeeeRegNr     String?
  deviceWeightG    Float?
  annualWeeeKg     Float?
  confidenceScore  Float?
  estimationMethod String?
  aiClassifiedAt   DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum LevyCategory {
  PRINTER_SCANNER_COPIER
  USB_STICK
  SSD_HDD
  MEMORY_CARD
  OPTICAL_MEDIA
  TABLET_SMARTPHONE
  PC_LAPTOP
  NOT_APPLICABLE
}

model ProductLevyProfile {
  id               String           @id @default(cuid())
  productId        String           @unique
  status           ComplianceStatus @default(UNKNOWN)
  levyCategory     LevyCategory?
  levyApplicable   Boolean?
  estimatedLevyEur Float?
  annualLevyEur    Float?
  zpuCategory      String?
  confidenceScore  Float?
  estimationMethod String?
  aiClassifiedAt   DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum ReachDeclarationStatus {
  NOT_CHECKED
  CHECKED_COMPLIANT
  DECLARATION_SENT
  NON_COMPLIANT
}

model ProductReachProfile {
  id                      String                 @id @default(cuid())
  productId               String                 @unique
  status                  ComplianceStatus       @default(UNKNOWN)
  containsSvhc            Boolean?
  aboveThreshold          Boolean?
  svhcSubstancesJson      String?
  declarationStatus       ReachDeclarationStatus?
  supplierDeclarationRecv Boolean?
  supplierDeclarationDate DateTime?
  confidenceScore         Float?
  estimationMethod        String?
  aiClassifiedAt          DateTime?
  notes                   String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  product                 Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
}

enum RohsStatus {
  COMPLIANT
  NON_COMPLIANT
  EXEMPTION
  NOT_CHECKED
}

model ProductRohsProfile {
  id               String           @id @default(cuid())
  productId        String           @unique
  status           ComplianceStatus @default(UNKNOWN)
  rohsApplicable   Boolean?
  rohsStatus       RohsStatus?
  ceMarkingPresent Boolean?
  docAvailable     Boolean?
  exemptionNumber  String?
  confidenceScore  Float?
  estimationMethod String?
  aiClassifiedAt   DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductEudrProfile {
  id                         String           @id @default(cuid())
  productId                  String           @unique
  status                     ComplianceStatus @default(UNKNOWN)
  containsRegulatedCommodity Boolean?
  commoditiesJson            String?
  countryOfOrigin            String?
  dueDiligenceRequired       Boolean?
  hasGeolocationData         Boolean?
  confidenceScore            Float?
  estimationMethod           String?
  aiClassifiedAt             DateTime?
  notes                      String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  product                    Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductPopProfile {
  id               String           @id @default(cuid())
  productId        String           @unique
  status           ComplianceStatus @default(UNKNOWN)
  containsPops     Boolean?
  substancesJson   String?
  isCompliant      Boolean?
  confidenceScore  Float?
  estimationMethod String?
  aiClassifiedAt   DateTime?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
}
